<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Enforce HTTPS and www
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^controvallc\.com [NC]
  RewriteRule ^(.*)$ https://www.controvallc.com/$1 [L,R=301]

  # 2. Remove trailing slashes (unless it's a directory or the root)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ /$1 [L,R=301]

  # 3. SPA Routing (fallback to index.html)
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>
